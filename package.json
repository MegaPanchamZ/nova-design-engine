{
  "name": "nova-design-engine",
  "private": false,
  "version": "0.1.0",
  "description": "Installable design engine toolkit with BYO LLM bindings",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js",
      "require": "./dist/parser.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./bindings": {
      "types": "./dist/bindings.d.ts",
      "import": "./dist/bindings.js",
      "require": "./dist/bindings.cjs"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.js",
      "require": "./dist/presets.cjs"
    },
    "./presets/default-editor-preset.json": "./presets/default-editor-preset.json",
    "./presets/editor-preset.schema.json": "./presets/editor-preset.schema.json"
  },
  "peerDependencies": {
    "konva": "^10.2.5",
    "react": "^18.3.0 || ^19.0.0",
    "react-konva": "^19.2.3",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "konva": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-konva": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "presets"
  ],
  "scripts": {
    "build": "npm run build:core",
    "build:core": "tsup",
    "build:adapters": "pnpm --dir packages/adapter-openai run build && pnpm --dir packages/adapter-google-genai run build",
    "build:all": "npm run build:core && npm run build:adapters",
    "prepare": "npm run build:core",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit && pnpm --dir packages/adapter-openai run typecheck && pnpm --dir packages/adapter-google-genai run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "bench:render": "vitest bench src/engine/render/renderer.bench.ts --run",
    "bench:browser": "playwright test tests/e2e/benchmark.spec.ts",
    "bench:browser:headed": "playwright test tests/e2e/benchmark.spec.ts --headed",
    "bench:browser:install": "playwright install chromium",
    "docs:dev": "npx @mintlify/cli dev",
    "docs:validate": "npx @mintlify/cli validate"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@chenglou/pretext": "^0.0.6",
    "@google/genai": "^1.29.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svg2pdf.js": "^2.7.0",
    "use-image": "^1.1.4",
    "uuid": "^14.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "konva": "^10.2.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@playwright/test": "^1.53.2",
    "react-konva": "^19.2.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "~5.8.2",
    "vitest": "^4.1.5"
  }
}
